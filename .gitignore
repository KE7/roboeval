# ============================================
# roboeval .gitignore
# ============================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
MANIFEST

# --- Virtual environments ---
.venvs/
.venv/
venv/
env/

# --- Testing ---
.pytest_cache/
.hypothesis/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# --- IDE / Editor ---
.idea/
.vscode/
*.swp
*.swo
*~
.ruff_cache/
.mypy_cache/

# --- Shell scripts in repo root ---
/*.sh

# --- Archived scripts ---
scripts/legacy/
scripts/README.md

# --- Project docs excluded from release ---
docs/competitive_analysis.md
docs/review_*
docs/audit_*
docs/*paper_findings*
docs/*paper_results*
docs/pi05_paper_libero_results.md
docs/published_paper_results.md
docs/smolvla_paper_findings.md
docs/openvla_paper_findings.md
docs/isaac_*
docs/ik_*
