# ============================================
# robo-eval .gitignore
# ============================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
MANIFEST

# --- Virtual environments ---
.venvs/
.venv/
venv/
env/

# --- Testing ---
.pytest_cache/
.hypothesis/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# --- IDE / Editor ---
.idea/
.vscode/
*.swp
*.swo
*~
.ruff_cache/
.mypy_cache/

# --- Legacy shell scripts in repo root ---
/*.sh

# --- Legacy scripts ---
scripts/legacy/
scripts/README.md

# --- Internal / development docs ---
