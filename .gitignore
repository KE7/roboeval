docs/libero_pro_audit_report.md

# --- Results / experiment data ---
/results/
outputs/
libero_spatial*/
sim_experience/
demo_videos/
liten_context/
liten_examples/
planner_context/

# --- Log files ---
logs/
scratch/
*.log
MUJOCO_LOG.TXT

# --- Local config files ---
litellm_*.yaml

# --- Notification scripts ---
notify_*.sh

# --- Temp artifacts ---
echo
EXIT:*
Exit:*

# --- Architecture notes ---
sims/vla_policies/ARCHITECTURE.md

# --- Lock files ---
# uv.lock is a local resolver lockfile for uv; users may install via pip,
# so we don't commit it.
uv.lock

# --- Binary artifacts ---
*.whl

# --- Reports / development artifacts ---
GRIPPER_*.md
GRIPPER_*.txt
GROOT_*.md
INTERNVLA_*.md
TASK_COMPLETION_REPORT.txt
bench_output.log
monitor_actions.py
wait_test.sh
MUJOCO_LOG.TXT

